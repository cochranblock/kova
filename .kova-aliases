alias kmt='kova micro tournament'
alias kmb='kova micro bench'
alias kmbr='kova micro bench --registry'
alias kme='kova micro export'
alias kmed='kova micro export --format dpo'
alias kmes='kova micro export --format sft'
alias kmts='kova micro train-stats'
alias kmtn='kova micro train'
alias kmtns='kova micro train --format sft'
alias kmtnd='kova micro train --format dpo'
alias kmtna='kova micro train-all'
alias kma='kova micro academy'
alias kmm='kova micro mine'
alias kmme='kova micro mine-export'

# c2 wake (Wake-on-LAN)
alias kwlf='kova c2 wake lf'
alias kwgd='kova c2 wake gd'
alias kwbt='kova c2 wake bt'
alias kwall='kova c2 wake lf && kova c2 wake gd && kova c2 wake bt'

# SSH tunnels (autossh to kova serve on worker nodes, port 3002)
# _at = autossh tunnel shorthand
_at() { AUTOSSH_GATETIME=0 autossh -M 0 -f -N -o ServerAliveInterval=15 -o ServerAliveCountMax=5 -L "$1:localhost:3002" "$2"; }
# per-node tunnels (local ports 3003-3006 → remote 3002)
alias ktgd='_at 3003 gd && echo "gd=3003"'
alias ktbt='_at 3004 bt && echo "bt=3004"'
alias ktst='_at 3005 st && echo "st=3005"'
alias ktlf='_at 3006 lf && echo "lf=3006"'
# all tunnels
ktun() { pkill -f "autossh.*300[3-6]" 2>/dev/null; sleep 1; _at 3003 gd; _at 3004 bt; _at 3005 st; _at 3006 lf; echo "tunnels: gd=3003 bt=3004 st=3005 lf=3006"; }
alias ktunk='pkill -f "autossh.*300[3-6]" && echo "tunnels killed"'
# status (kova serve uses /v1/models, OpenAI-compat)
_tp() { curl -s --max-time 3 "http://localhost:$1/v1/models" 2>/dev/null | grep -q '"data"' && echo "$1($2): OK" || echo "$1($2): DOWN"; }
ktuns() { _tp 3003 gd; _tp 3004 bt; _tp 3005 st; _tp 3006 lf; }
# Legacy ollama tunnels (keep until migration complete)
_at_legacy() { AUTOSSH_GATETIME=0 autossh -M 0 -f -N -o ServerAliveInterval=15 -o ServerAliveCountMax=5 -L "$1:localhost:11434" "$2"; }
alias ktgd_ollama='_at_legacy 11435 gd && echo "gd=11435 (ollama)"'
alias ktun_ollama='pkill -f "autossh.*1143" 2>/dev/null; sleep 1; _at_legacy 11435 gd; _at_legacy 11436 bt; _at_legacy 11437 st; _at_legacy 11438 lf; echo "ollama tunnels: gd=11435 bt=11436 st=11437 lf=11438"'

# Deploy aliases to all nodes (/etc/profile.d/)
kad() {
    for h in gd st lf bt; do
        scp -q "$HOME/.kova-aliases" "$h":~/.kova-aliases 2>/dev/null
        ssh -o ConnectTimeout=5 "$h" "su -c 'cp /home/mcochran/.kova-aliases /etc/profile.d/kova-aliases.sh'" 2>/dev/null && echo "$h: deployed" || echo "$h: FAILED"
    done
}

# Parallel SSH (kept from original)
sshall() {
    if [ $# -eq 0 ]; then
        echo -e "\033[38;5;202m[ x ] No command.\033[0m"
        return 1
    fi
    for node in lf gd bt st; do
        echo -e "\033[38;5;226m[ > ] $node\033[0m"
        ssh "$node" "$@"
    done
    echo -e "\033[38;5;135m[ ok ] done\033[0m"
}

sshallp() {
    if [ $# -eq 0 ]; then
        echo -e "\033[38;5;202m[ x ] No command.\033[0m"
        return 1
    fi
    for node in lf gd bt st; do
        echo -e "\033[38;5;226m[ > ] $node\033[0m"
        ssh "$node" "$@" &
    done
    wait
    echo -e "\033[38;5;135m[ ok ] done\033[0m"
}
