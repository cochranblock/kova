# p9=wowasticker
alias p9='cd "${_KH}/wowasticker"'
alias p9b='cd "${_KH}/wowasticker" && cargo build'
alias p9c='cd "${_KH}/wowasticker" && cargo check'
alias p9t='cd "${_KH}/wowasticker" && cargo test'
alias p9r='cd "${_KH}/wowasticker" && cargo run'

# dN = deploy tokens: sync source → build on bt → copy binary → restart on gd
# Pattern: d<project>s = sync, d<project>b = build, d<project>d = deploy (full), d<project>r = restart

# d3 = oakilydokily deploy pipeline (build on bt, deploy to gd)
d3s() { rsync -avz --exclude target --exclude .git "${_KH}/oakilydokily/" bt:/home/mcochran/oakilydokily/; }
d3b() { ssh bt 'export PATH="$HOME/.cargo/bin:$PATH"; cd /home/mcochran && cargo build -p oakilydokily --release --features approuter'; }
d3c() { scp bt:/home/mcochran/target/release/oakilydokily /tmp/oakilydokily-release && scp /tmp/oakilydokily-release gd:/home/mcochran/bin/oakilydokily; }
d3r() { ssh gd 'systemctl --user restart oakilydokily'; }
d3d() { echo "d3: sync→build→copy→restart"; d3s && d3b && d3c && d3r && echo "d3: oakilydokily deployed"; }
d3dp() { (cd "${_KH}/oakilydokily" && git push) && d3d; }

# d0 = kova deploy pipeline (build on bt, deploy to all nodes)
d0s() { rsync -avz --exclude target --exclude .git "${_KH}/kova/" bt:/home/mcochran/kova/; }
d0b() { ssh bt 'export PATH="$HOME/.cargo/bin:$PATH"; cd /home/mcochran && cargo build -p kova --release --features serve'; }

# d1 = approuter deploy pipeline
d1s() { rsync -avz --exclude target --exclude .git "${_KH}/approuter/" bt:/home/mcochran/approuter/; }
d1b() { ssh bt 'export PATH="$HOME/.cargo/bin:$PATH"; cd /home/mcochran && cargo build -p approuter --release'; }
d1c() { scp bt:/home/mcochran/target/release/approuter /tmp/approuter-release && scp /tmp/approuter-release gd:/home/mcochran/bin/approuter; }
d1dp() { (cd "${_KH}/approuter" && git push) && d1s && d1b && d1c; }

# d2 = cochranblock deploy pipeline (sync→bt build→copy→gd restart)
d2s() { rsync -avz --exclude target --exclude .git "${_KH}/cochranblock/" bt:/home/mcochran/cochranblock/; }
d2b() { ssh bt 'export PATH="$HOME/.cargo/bin:$PATH"; cd /home/mcochran && cargo build -p cochranblock --release --features approuter'; }
d2c() { scp bt:/home/mcochran/target/release/cochranblock /tmp/cochranblock-release && scp /tmp/cochranblock-release gd:/home/mcochran/bin/cochranblock; }
d2r() { ssh gd 'pkill -f cochranblock 2>/dev/null; cd /home/mcochran/bin && nohup ./cochranblock </dev/null >>/tmp/cochranblock.log 2>&1 &'; }
d2d() { echo "d2: sync→build→copy→restart"; d2s && d2b && d2c && d2r && echo "d2: cochranblock deployed"; }
d2dp() { (cd "${_KH}/cochranblock" && git push) && d2d; }
alias redeploy='d2d'   # cochranblock: rebuild via ssh (bt) + redeploy to gd

# dw = sync workspace (Cargo.toml, lock, vendor) to bt
dws() { rsync -avz "${_KH}/Cargo.toml" "${_KH}/Cargo.lock" bt:/home/mcochran/ && rsync -avz "${_KH}/vendor/" bt:/home/mcochran/vendor/; }

# dm = build mural-wasm (local only — needs wasm32 target)
dm() { cargo build --target wasm32-unknown-unknown -p mural-wasm --release && cp "${_KH}/target/wasm32-unknown-unknown/release/mural-wasm.wasm" "${_KH}/oakilydokily/assets/mural-wasm.wasm" && echo "mural-wasm built"; }

# micro = tournament + bench + training
alias kmt='kova micro tournament'
alias kmb='kova micro bench'
alias kmbr='kova micro bench --registry'
alias kme='kova micro export'
alias kmed='kova micro export --format dpo'
alias kmes='kova micro export --format sft'
alias kmts='kova micro train-stats'
alias kmtn='kova micro train'
alias kma='kova micro academy'
alias kmm='kova micro mine'
alias kmme='kova micro mine-export'

# c2 wake (Wake-on-LAN)
alias kwlf='kova c2 wake lf'
alias kwgd='kova c2 wake gd'
alias kwbt='kova c2 wake bt'
alias kwall='kova c2 wake lf && kova c2 wake gd && kova c2 wake bt'

# SSH tunnels (autossh to ollama on worker nodes)
# _at = autossh tunnel shorthand
_at() { AUTOSSH_GATETIME=0 autossh -M 0 -f -N -o ServerAliveInterval=15 -o ServerAliveCountMax=5 -L "$1:localhost:11434" "$2"; }
# per-node tunnels
alias ktgd='_at 11435 gd && echo "gd=11435"'
alias ktbt='_at 11436 bt && echo "bt=11436"'
alias ktst='_at 11437 st && echo "st=11437"'
alias ktlf='_at 11438 lf && echo "lf=11438"'
# all tunnels
ktun() { pkill -f "autossh.*1143" 2>/dev/null; sleep 1; _at 11435 gd; _at 11436 bt; _at 11437 st; _at 11438 lf; echo "tunnels: gd=11435 bt=11436 st=11437 lf=11438"; }
alias ktunk='pkill -f "autossh.*1143" && echo "tunnels killed"'
# status
_tp() { local n=$(curl -s --max-time 3 "http://localhost:$1/api/tags" 2>/dev/null); [ -n "$n" ] && echo "$1($2): $(echo "$n" | python3 -c "import sys,json; print(len(json.load(sys.stdin).get('models',[])))" 2>/dev/null) models" || echo "$1($2): DOWN"; }
ktuns() { _tp 11435 gd; _tp 11436 bt; _tp 11437 st; _tp 11438 lf; }

# Deploy aliases to all nodes (/etc/profile.d/)
kad() {
    for h in gd st lf bt; do
        scp -q "$HOME/.kova-aliases" "$h":~/.kova-aliases 2>/dev/null
        ssh -o ConnectTimeout=5 "$h" "su -c 'cp /home/mcochran/.kova-aliases /etc/profile.d/kova-aliases.sh'" 2>/dev/null && echo "$h: deployed" || echo "$h: FAILED"
    done
}

# Parallel SSH (kept from original)
sshall() {
    if [ $# -eq 0 ]; then
        echo -e "\033[38;5;202m[ x ] No command.\033[0m"
        return 1
    fi
    for node in lf gd bt st; do
        echo -e "\033[38;5;226m[ > ] $node\033[0m"
        ssh "$node" "$@"
    done
    echo -e "\033[38;5;135m[ ok ] done\033[0m"
}

sshallp() {
    if [ $# -eq 0 ]; then
        echo -e "\033[38;5;202m[ x ] No command.\033[0m"
        return 1
    fi
    for node in lf gd bt st; do
        echo -e "\033[38;5;226m[ > ] $node\033[0m"
        ssh "$node" "$@" &
    done
    wait
    echo -e "\033[38;5;135m[ ok ] done\033[0m"
}
