# Kova §13 Tokenized Shell Aliases
# Sourced by .zshrc (macOS) and .bashrc (Debian workers)
# k=kova, ks=serve, kg=gui, kc=chat, kx=cargo, kn=node, kt=test

# Path tokens — shorten output and prompts
export W="$HOME"
export K="$HOME/kova"
export KS="$HOME/kova/src"

# Reload aliases
alias ka='. "$HOME/.kova-aliases" && echo "aliases reloaded"'

# Base
alias k='kova'
alias ks='kova s'
alias ksd='kova s -d'
alias kg='kova gui'
alias kgd='kova gui --demo'
alias kc='kova chat'
alias kt='kova test'
alias kb='kova bootstrap'
alias kr='kova recent'
alias km='kova model'
alias kmi='kova model install'
alias kml='kova model list'
alias kp='kova prompts'

