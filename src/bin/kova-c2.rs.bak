//! kova-c2 — Tokenized orchestration binary for c2-core.
//!
//! Dispatches tokenized commands (f18–f23) locally or broadcasts to swarm (lf gd bt st).
//! Replaces sshall + manual intent with a single typed binary.

#![allow(non_camel_case_types)]

use clap::{Parser, Subcommand, ValueEnum};
use std::path::PathBuf;
use std::process::Command;

/// Tokenized command. Maps to kova-core t1 IntentKind.
#[derive(Clone, Copy, ValueEnum)]
enum Token {
    /// f18 — Compile (cargo build). --release for release.
    F18,
    /// f19 — Test (cargo test)
    F19,
    /// f20 — Full pipeline (cargo check + cargo test)
    F20,
    /// f21 — Tunnel update (approuter --update-tunnel). Local only.
    F21,
    /// f22 — Setup roguerepo (approuter --setup-roguerepo). Local only.
    F22,
    /// f23 — Cloudflare purge. Local only.
    F23,
}

impl Token {
    fn to_intent(self) -> kova_core::t0 {
        match self {
            Token::F18 => kova_core::t0::f18(false),
            Token::F19 => kova_core::t0::f19(),
            Token::F20 => kova_core::t0::f20(),
            Token::F21 => kova_core::t0::f21(),
            Token::F22 => kova_core::t0::f22(),
            Token::F23 => kova_core::t0::f23(),
        }
    }

    fn name(&self) -> &'static str {
        match self {
            Token::F18 => "f18",
            Token::F19 => "f19",
            Token::F20 => "f20",
            Token::F21 => "f21",
            Token::F22 => "f22",
            Token::F23 => "f23",
        }
    }

    /// Commands that must run on c2-core (approuter, cloudflare).
    fn is_local_only(&self) -> bool {
        matches!(self, Token::F21 | Token::F22 | Token::F23)
    }
}

#[derive(Parser)]
#[command(name = "kova-c2", version, about = "Tokenized orchestration for Kova swarm")]
struct Args {
    #[command(subcommand)]
    cmd: Cmd,
}

#[derive(Subcommand)]
enum Cmd {
    /// Run tokenized command. f18–f23.
    Run {
        /// Token: f18, f19, f20, f21, f22, f23
        #[arg(value_enum)]
        token: Token,
        /// Project path. Default: KOVA_PROJECT or config or cwd.
        #[arg(short, long)]
        project: Option<PathBuf>,
        /// Broadcast to all workers (lf gd bt st). Ignored for f21/f22/f23.
        #[arg(short, long)]
        broadcast: bool,
        /// For f18: build --release
        #[arg(long)]
        release: bool,
    },
    /// List nodes (from config or default lf gd bt st).
    Nodes,
}

/// Default worker nodes. Matches sshall in .zshrc.
fn default_nodes() -> Vec<&'static str> {
    vec!["lf", "gd", "bt", "st"]
}

/// Resolve project path.
fn resolve_project(project: Option<PathBuf>) -> PathBuf {
    project
        .or_else(|| std::env::var("KOVA_PROJECT").ok().map(PathBuf::from))
        .filter(|p| p.exists())
        .unwrap_or_else(|| std::env::current_dir().unwrap_or_else(|_| PathBuf::from(".")))
}

/// Map c2-core path to worker path. ~/hive-vault -> /mnt/hive.
fn to_worker_path(p: &Path) -> PathBuf {
    let s = p.to_string_lossy();
    if let Ok(home) = std::env::var("HOME") {
        let hive_vault = format!("{}/hive-vault", home);
        if s.starts_with(&hive_vault) {
            let rest = s.strip_prefix(&hive_vault).unwrap_or("");
            return PathBuf::from("/mnt/hive").join(rest.trim_start_matches('/'));
        }
    }
    p.to_path_buf()
}

/// Run plan locally via kova compute.
fn run_local(plan: &kova::plan::t3) -> anyhow::Result<()> {
    let exec = kova::compute::t6;
    let results = exec.f15(plan)?;
    for r in &results {
        let mark = if r.s11 { "✓" } else { "✗" };
        eprintln!("{} {} {}", mark, r.s10, if r.s13.is_empty() { "" } else { &r.s13 });
    }
    let all_ok = results.iter().all(|r| r.s11);
    if !all_ok {
        anyhow::bail!("One or more actions failed");
    }
    Ok(())
}

/// Broadcast command to workers via SSH.
fn run_broadcast(plan: &kova::plan::t3, nodes: &[&str]) -> anyhow::Result<()> {
    let worker_path = to_worker_path(&plan.s4);
    for step in &plan.s3 {
        let cmd = match &step.s6 {
            kova::plan::t5::CargoCheck => "cargo check",
            kova::plan::t5::CargoTest => "cargo test",
            kova::plan::t5::CargoBuild { release } => {
                if *release {
                    "cargo build --release"
                } else {
                    "cargo build"
                }
            }
            _ => continue,
        };
        for node in nodes {
            eprintln!("[ ❯ ] {} → {}", node, cmd);
            let status = Command::new("ssh")
                .arg(*node)
                .arg(format!("cd {} && {}", worker_path.display(), cmd))
                .status()?;
            if !status.success() {
                anyhow::bail!("{} failed on {}", cmd, node);
            }
        }
    }
    eprintln!("[ ✔ ] Broadcast complete");
    Ok(())
}

fn main() -> anyhow::Result<()> {
    kova::bootstrap()?;

    let args = Args::parse();
    match args.cmd {
        Cmd::Nodes => {
            for n in default_nodes() {
                println!("{}", n);
            }
            Ok(())
        }
        Cmd::Run {
            token,
            project,
            broadcast,
            release,
        } => {
            let project_path = resolve_project(project);
            let intent = match (token, release) {
                (Token::F18, true) => kova_core::t0::f18(true),
                _ => token.to_intent(),
            };

            let approuter_dir = std::env::var("HOME")
                .ok()
                .map(|h| PathBuf::from(h).join("approuter"));
            let plan = kova::plan::t3::f14(&intent, project_path, approuter_dir);

            if plan.s3.is_empty() {
                eprintln!("No actions for {}", token.name());
                return Ok(());
            }

            if token.is_local_only() {
                run_local(&plan)
            } else if broadcast {
                run_broadcast(&plan, &default_nodes())
            } else {
                run_local(&plan)
            }
        }
    }
}
